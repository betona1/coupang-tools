# ───────────────────────────────────────────────────────────
# 쿠팡 통합 운영 도구 — 환경설정 템플릿
# 이 파일을 ".env" 로 복사하고 실제 값으로 채우세요. (.env 는 깃에 안 올라감)
# ───────────────────────────────────────────────────────────

# ── DB (상품/광고/정산/계정) ──
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ads
DB_USER=여기에_DB아이디
DB_PASSWORD=여기에_DB비번

# ── DB (주문/리뷰/가구매) ──
JOACHAM_DB_HOST=127.0.0.1
JOACHAM_DB_PORT=3306
JOACHAM_DB_NAME=joacham
JOACHAM_DB_USER=여기에_DB아이디
JOACHAM_DB_PASSWORD=여기에_DB비번

# ── 암호화 키 (DB에 저장되는 API키/WING비번 Fernet 암호화용) ──
# 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=여기에_Fernet키

# ── 가구매방 (crossbuy) 로그인 ──
GAGUMAE_BASE=http://가구매방호스트:포트
GAGUMAE_USER=여기에_가구매방아이디
GAGUMAE_PW=여기에_가구매방비번
